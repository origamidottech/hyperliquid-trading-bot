{
  "name": "hyperliquid-copy-trading-bot",
  "version": "1.0.0",
  "description": "Hyperliquid perpetual copy trading bot — mirrors a target trader's perp trades in real-time",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dev:watch": "ts-node-dev --respawn --transpile-only src/index.ts",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@nktkas/hyperliquid": "^0.32.2",
    "kelly-stake": "^3.1.0",
    "chalk": "^4.1.2",
    "dotenv": "^16.4.7",
    "viem": "^2.21.58",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.11",
    "@types/winston": "^2.4.4",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
