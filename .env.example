# check readme.md for more information

PRIVATE_KEY=0xabcd....abcd

TARGET_TRADER=0x393d0b87ed38fc779fd9611144ae649ba6082109

SIZE_MULTIPLIER=1.0

MAX_POSITION_SIZE_USD=1000

MAX_TOTAL_EXPOSURE_USD=5000

MAX_LEVERAGE=10

# ─── Kelly criterion position sizing (@zscdao/kelly) ───────────────────────────
# When enabled, each copied open is capped at the fractional-Kelly stake of your
# account value, derived from the target trader's realised edge. Never sizes
# above the mirrored size or MAX_POSITION_SIZE_USD.
KELLY_ENABLED=false

# Fractional-Kelly multiplier (0,1]. 0.5 = half-Kelly (recommended, less variance).
KELLY_FRACTION=0.5

# Hard cap on the equity fraction staked per copy (0,1].
KELLY_MAX_FRACTION=0.2

# Rolling window of the target's recent trades used to estimate edge.
KELLY_WINDOW=50

# Minimum target closes before Kelly engages (else falls back to the mirror).
KELLY_MIN_SAMPLES=10

STOP_LOSS_PERCENT=0

STOP_LOSS_CHECK_INTERVAL_MS=5000

MAX_DAILY_LOSS_USD=500

COPY_EXISTING_POSITIONS=false

CLOSE_ON_EXIT=false

RECONCILE_INTERVAL_MS=60000

SLIPPAGE_BPS=50

NETWORK=mainnet

LOG_LEVEL=info

LOG_TO_FILE=true
